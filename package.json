{
	"name": "pandame",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write . && npm run lint:fix",
		"postinstall:copy-auth": "node -e \"require('fs').cpSync('node_modules/@junobuild/core-peer/dist/workers/', './static/workers', {recursive: true});\"",
		"postinstall": "npm run postinstall:copy-auth",
		"test": "vitest",
		"i18n": "vite-node scripts/i18n.ts && prettier --write ./src/lib/types/i18n.d.ts",
		"playwright:install": "playwright install --with-deps",
		"e2e": "npm run playwright:install && playwright test",
		"e2e:ci": "npm run playwright:install && playwright test --reporter=html",
		"e2e:snapshots": "npm run playwright:install && playwright test --update-snapshots --reporter=list",
		"e2e:report": "npm run playwright:install && playwright show-report"
	},
	"devDependencies": {
		"@junobuild/config": "^0.1.1",
		"@junobuild/vite-plugin": "^0.0.19",
		"@playwright/test": "^1.50.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.15.1",
		"@sveltejs/vite-plugin-svelte": "^4.0.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@types/eslint": "^9.6.1",
		"@types/node": "^22.13.1",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.20.1",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^16.0.0",
		"jsdom": "^26.0.0",
		"postcss": "^8.5.3",
		"prettier": "^3.5.3",
		"prettier-plugin-organize-imports": "^4.1.0",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.20.4",
		"svelte-check": "^4.1.4",
		"tailwindcss": "^3.4.17",
		"tslib": "^2.8.0",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.26.1",
		"vite": "^6.2.4",
		"vite-node": "^3.0.3",
		"vitest": "^3.0.7"
	},
	"type": "module",
	"dependencies": {
		"@dfinity/utils": "^2.6.0",
		"@junobuild/core-peer": "^0.0.28",
		"nanoid": "^5.0.9"
	}
}
