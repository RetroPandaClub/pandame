{
	"name": "pandame",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --force",
		"build": "tsc --noEmit && vite build",
		"prepare": "svelte-kit sync",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --cache --check . && eslint . --cache",
		"format": "prettier --cache --write . && eslint . --cache --fix",
		"quality": "npm run format && npm run lint",
		"postinstall:copy-auth": "node -e \"require('fs').cpSync('node_modules/@junobuild/core/dist/workers/', './static/workers', {recursive: true});\"",
		"postinstall": "npm run postinstall:copy-auth",
		"test": "vitest",
		"i18n": "vite-node scripts/i18n.ts && prettier --write ./src/lib/types/i18n.d.ts",
		"playwright:install": "playwright install --with-deps",
		"e2e": "npm run playwright:install && playwright test",
		"e2e:ci": "npm run playwright:install && playwright test --reporter=html",
		"e2e:snapshots": "npm run playwright:install && playwright test --update-snapshots --reporter=list",
		"e2e:report": "npm run playwright:install && playwright show-report"
	},
	"devDependencies": {
		"@icp-sdk/bindgen": "^0.4.0",
		"@junobuild/config": "^3.0.1",
		"@junobuild/vite-plugin": "^4.7.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.37.0",
		"@sveltejs/vite-plugin-svelte": "^6.1.4",
		"@tailwindcss/postcss": "^4.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.6.3",
		"@types/eslint": "^9.6.1",
		"@types/node": "^25.3.3",
		"@types/qrcode": "^1.5.5",
		"eslint": "^9.34.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-svelte": "^3.12.1",
		"globals": "^16.5.0",
		"jsdom": "^26.0.0",
		"playwright": "^1.59.1",
		"postcss": "^8.5.13",
		"prettier": "^3.8.2",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"tslib": "^2.8.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.42.0",
		"vite": "^7.3.2",
		"vite-node": "^3.2.4",
		"vitest": "^3.2.4"
	},
	"type": "module",
	"dependencies": {
		"@dfinity/utils": "^4.2.1",
		"@icp-sdk/canisters": "^3.5.2",
		"@icp-sdk/core": "^5.0.0",
		"@junobuild/core": "^5.4.0",
		"@junobuild/schema": "^1.2.4",
		"nanoid": "^5.1.11",
		"qrcode": "^1.5.4"
	}
}
