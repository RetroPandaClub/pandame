{
	"name": "pandame",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write . && npm run lint:fix",
		"postinstall:copy-auth": "node -e \"require('fs').cpSync('node_modules/@junobuild/core-peer/dist/workers/', './static/workers', {recursive: true});\"",
		"postinstall": "npm run postinstall:copy-auth",
		"test": "vitest",
		"i18n": "vite-node scripts/i18n.ts && prettier --write ./src/lib/types/i18n.d.ts",
		"playwright:install": "playwright install --with-deps",
		"e2e": "npm run playwright:install && playwright test",
		"e2e:ci": "npm run playwright:install && playwright test --reporter=html",
		"e2e:snapshots": "npm run playwright:install && playwright test --update-snapshots --reporter=list",
		"e2e:report": "npm run playwright:install && playwright show-report"
	},
	"devDependencies": {
		"@junobuild/config": "^0.0.16",
		"@junobuild/vite-plugin": "^0.0.18",
		"@playwright/test": "^1.48.2",
		"@sveltejs/adapter-static": "^3.0.5",
		"@sveltejs/kit": "^2.7.2",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@types/eslint": "^9.6.1",
		"@types/node": "^22.9.3",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.14.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-svelte": "^2.46.0",
		"globals": "^15.11.0",
		"jsdom": "^25.0.1",
		"postcss": "^8.4.47",
		"prettier": "^3.3.3",
		"prettier-plugin-organize-imports": "^4.1.0",
		"prettier-plugin-svelte": "^3.2.7",
		"prettier-plugin-tailwindcss": "^0.6.9",
		"svelte": "^5.1.9",
		"svelte-check": "^4.0.5",
		"tailwindcss": "^3.4.14",
		"tslib": "^2.8.0",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.11.0",
		"vite": "^5.4.10",
		"vite-node": "^2.1.4",
		"vitest": "^2.1.4"
	},
	"type": "module",
	"dependencies": {
		"@dfinity/utils": "^2.6.0",
		"@junobuild/core-peer": "^0.0.28",
		"nanoid": "^5.0.7"
	}
}
